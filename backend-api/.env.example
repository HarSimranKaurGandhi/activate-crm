APP_NAME="Fitness Quotation API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.your-domain.com
FRONTEND_URL=https://your-react-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=srv0000.hstgr.io
DB_PORT=3306
DB_DATABASE=your_existing_database
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

SANCTUM_STATEFUL_DOMAINS=your-react-domain.com
CORS_ALLOWED_ORIGINS=https://your-react-domain.com,http://localhost:5173,http://localhost:5174

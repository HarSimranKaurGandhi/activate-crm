APP_NAME="Fitness Quotation API"
APP_ENV=production
APP_KEY=base64:QBI3oSx0DgEb1iijXrgJmOxqZ627Yl4Wosbpg8uvIko=
APP_DEBUG=false
APP_URL=https://crmapi.activatefitnessstore.com
FRONTEND_URL=https://crm.activatefitnessstore.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
# Use localhost when PHP runs on the same Hostinger server as MySQL
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
#MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# PDF: use dompdf on Hostinger shared hosting (no Node). auto | dompdf | playwright
QUOTATION_PDF_DRIVER=dompdf

# Optional: override upload destination when Laravel lives outside the web root.
# Example for Hostinger:
# PUBLIC_UPLOAD_ROOT=/home/your-user/domains/activatefitnessstore.com/public_html/crm_api
# Uploaded files will then be stored under PUBLIC_UPLOAD_ROOT/uploads/...
PUBLIC_UPLOAD_ROOT=

SANCTUM_STATEFUL_DOMAINS=crm.activatefitnessstore.com
CORS_ALLOWED_ORIGINS=https://crm.activatefitnessstore.com,http://localhost:5173
